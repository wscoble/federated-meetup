# .env.example — federated-meetup environment variables.
# Copy to .env and edit before running `docker compose up`.

# ---- Required ----

# The group's Ed25519 public key (hex, 32 bytes / 64 hex chars).
# Generate one: python3 -c "print('aa'*32)"
# Or: openssl rand -hex 32
HOSTD_GROUP_KEY=

# Your domain name (used by Caddy for automatic HTTPS).
DOMAIN=localhost

# ---- Optional (with defaults) ----

# Canonical name this host advertises in MCP discovery.
HOSTD_NAME=hostd

# Public base URL for absolute links and JSON-LD.
# Set to your HTTPS URL in production.
HOSTD_BASE_URL=https://localhost

# SQLite path for the web store (RSVPs, sessions, event cache).
# Inside Docker, this is a mounted volume.
HOSTD_DB_PATH=/data/fedmeetup.db

# SQLite path for the protocol transition log.
# If empty, protocol state is in-memory only (lost on restart).
# Set this to persist group state across restarts.
HOSTD_PROTOCOL_DB=/data/protocol.db

# Host description for MCP discovery endpoints.
HOSTD_DESCRIPTION=Federated Meetup host

# Geographic area for discovery (e.g. "Las Vegas, NV").
HOSTD_AREA=

# Initial threshold for the steward multisig (v0: unused).
HOSTD_THRESHOLD=0

# ---- Federation sync (optional — omit to run standalone) ----

# Comma-separated peer URLs to sync from (e.g. "http://peer:8080").
HOSTD_PEERS=

# Bootstrap from peers on startup (true/false).
HOSTD_SYNC_BOOTSTRAP=true

# Maintain live Subscribe streams after bootstrap (true/false).
HOSTD_SYNC_LIVE=true

# ---- Payments (optional) ----

# Stripe secret key. If unset, mock payments are used.
# STRIPE_SECRET_KEY=